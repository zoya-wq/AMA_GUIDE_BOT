# Azure Configuration
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=your-key-here

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-key-here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4

AZURE_COSMOS_CONNECTION_STRING=AccountEndpoint=https://your-account.documents.azure.com:443/;AccountKey=your-key; 
AZURE_COSMOS_DATABASE=ama_guides
AZURE_COSMOS_CONTAINER=ama_content

# Qdrant Configuration (Cloud)
QDRANT_URL=https://YOUR-CLUSTER-ID.eu-central-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key-here

# Application Settings
EMBEDDING_DIMENSIONS=3072
CHUNK_SIZE=512
CHUNK_OVERLAP=50
